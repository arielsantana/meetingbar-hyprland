// Add this block to your Waybar config (e.g. ~/.config/waybar/config).
// Also add "custom/meetingbar" to your modules-left/right/center array.
// install.sh prints the exact exec line with the correct path for your system.
{
    "custom/meetingbar": {
        "exec": "python3 {INSTALL_DIR}/waybar.py",
        "interval": 30,
        "return-type": "json",
        "format": "{}"
    }
}
